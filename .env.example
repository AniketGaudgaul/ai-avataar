# ---------------------------------------------------------------------------
# AI Avatar — environment configuration
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# ---------------------------------------------------------------------------

# --- App ---
APP_ENV=local                 # local | production
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins for the chat widget.
# In production this must include the GitHub Pages origin, e.g.
#   CORS_ORIGINS=https://aniketgaudgaul.github.io
# Origin only — no path, no trailing slash.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Where figure bytes live. Chunks store a uri relative to this (app/core/assets.py).
# The container sets ASSETS_DIR=/app/assets; locally the repo's assets/ is right.
ASSETS_DIR=assets

# The public origin this API is served from, e.g. https://ai-avatar.up.railway.app
# Needed so /chat returns ABSOLUTE figure URLs: the widget runs on GitHub Pages, so
# a relative "/images/..." would resolve against the portfolio, not this API.
# Leave empty for local dev (same origin).
PUBLIC_BASE_URL=

# --- Gemini (Google GenAI) ---
# Get a key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_ROUTER_MODEL=gemini-2.5-flash-lite
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIM=1536

# --- LlamaParse (document parsing, vector path) --- INGEST ONLY ---
# Not needed by the deployed API: the container installs no `[ingest]` extra and
# never parses a document. Set this on the dev box only.
# Get a key from https://cloud.llamaindex.ai (free tier). Uses LlamaParse v2.
LLAMA_CLOUD_API_KEY=
LLAMA_PARSE_TIER=agentic_plus         # fast | cost_effective | agentic | agentic_plus
LLAMA_PARSE_CHART_PARSING=agentic     # agentic | agentic_plus | efficient

# --- Vector store (Qdrant) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=ai_avatar_chunks

# --- Knowledge graph (Neo4j) ---
# For AuraDB: URI is neo4j+s://<instance-id>.databases.neo4j.io, user and database
# are both the instance id (NOT "neo4j") — check with `SHOW DATABASES` if unsure.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please_change_me
NEO4J_DATABASE=neo4j

# --- Tracing (Langfuse, optional / Phase D) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
