# Keep the build context small and secret-free.
# Note: `assets/` is deliberately NOT ignored — the figure bytes must ship, or
# the deployed agent silently shows no diagrams (see app/core/assets.py).

.git
.github
.venv
venv
__pycache__
*.py[cod]
*.egg-info/
build/
dist/

# Secrets — never bake these into a layer. Railway injects them as env vars.
.env
.env.*
!.env.example

# Index-building inputs and intermediates. The container serves an index that
# already exists in Qdrant/Neo4j; it never rebuilds one.
temp_data/
evals/
tests/
scripts/
docs/
notebooks/

# Local tooling / editor state
.ruff_cache/
.pytest_cache/
.mypy_cache/
.vscode/
.idea/
*.log
*.sqlite
